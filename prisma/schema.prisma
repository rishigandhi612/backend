generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Inventory {
  id            String    @id @default(uuid())
  productId     String
  width         Float?
  netWeight     Float
  grossWeight   Float?
  rollId        String    @unique
  micron        Float?
  mtr           Float?
  type          String    @default("film")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  status        String    @default("available")
  invoiceNumber String?
  soldAt        DateTime?

  @@index([productId])
  @@index([rollId])
  @@index([status])
}

model LedgerAccount {
  id           String            @id @default(uuid())
  code         String            @unique
  name         String
  type         LedgerAccountType
  description  String?
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  debitEntries VoucherEntry[]    @relation("DebitAccount")

  @@index([type])
  @@index([isActive])
  @@map("ledger_accounts")
}

model Bill {
  id               String           @id @default(uuid())
  mongoInvoiceId   String?          @unique
  invoiceNumber    String           @unique
  customerId       String
  billAmount       Decimal          @db.Decimal(12, 2)
  allocatedAmount  Decimal          @default(0) @db.Decimal(12, 2)
  isOpeningBalance Boolean          @default(false)
  invoiceDate      DateTime
  dueDate          DateTime?
  financialYear    String
  openingBalanceId String?          @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  allocations      BillAllocation[]
  invoiceNotes     InvoiceNote[]
  openingBalance   OpeningBalance?  @relation(fields: [openingBalanceId], references: [id])

  @@index([customerId])
  @@index([financialYear])
  @@index([customerId, financialYear])
  @@index([isOpeningBalance])
  @@map("bills")
}

model OpeningBalance {
  id            String   @id @default(uuid())
  referenceNo   String   @unique
  customerId    String
  customerName  String
  amount        Decimal  @db.Decimal(12, 2)
  narration     String?
  asOfDate      DateTime
  financialYear String
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bill          Bill?

  @@index([customerId])
  @@index([financialYear])
  @@map("opening_balances")
}

model Voucher {
  id              String           @id @default(uuid())
  voucherId       String           @unique
  customerId      String
  type            VoucherType
  totalAmount     Decimal          @db.Decimal(12, 2)
  onAccountAmount Decimal          @default(0) @db.Decimal(12, 2)
  paymentMethod   PaymentMethod
  bankId          String?
  bankName        String?
  chequeNumber    String?
  chequeDate      DateTime?
  utrNumber       String?
  upiRef          String?
  reference       String?
  narration       String?
  voucherDate     DateTime
  financialYear   String
  createdBy       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  allocations     BillAllocation[]
  entries         VoucherEntry[]

  @@index([customerId])
  @@index([type])
  @@index([bankId])
  @@index([voucherDate])
  @@index([customerId, voucherDate])
  @@index([financialYear])
  @@index([customerId, onAccountAmount])
  @@map("vouchers")
}

model VoucherEntry {
  id              String        @id @default(uuid())
  voucherId       String
  ledgerAccountId String
  entryType       EntryType
  amount          Decimal       @db.Decimal(12, 2)
  narration       String?
  createdAt       DateTime      @default(now())
  voucher         Voucher       @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  debitAccount    LedgerAccount @relation("DebitAccount", fields: [ledgerAccountId], references: [id], map: "voucher_entry_debit_fk")

  @@index([voucherId])
  @@index([ledgerAccountId])
  @@map("voucher_entries")
}

model BillAllocation {
  id              String   @id @default(uuid())
  voucherId       String
  billId          String?
  customerId      String
  allocatedAmount Decimal  @db.Decimal(12, 2)
  narration       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  bill            Bill?    @relation(fields: [billId], references: [id], onDelete: Restrict)
  voucher         Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@index([voucherId])
  @@index([billId])
  @@index([customerId])
  @@index([customerId, billId])
  @@map("bill_allocations")
}

model InvoiceNote {
  id            String        @id @default(uuid())
  noteNumber    String        @unique
  noteType      NoteType
  documentType  DocumentType
  balanceEffect BalanceEffect
  status        NoteStatus    @default(POSTED)
  billId        String?
  invoiceNumber String
  customerId    String?
  supplierId    String?
  amount        Decimal       @db.Decimal(12, 2)
  noteDate      DateTime
  financialYear String
  reason        String?
  narration     String?
  createdBy     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  bill          Bill?         @relation(fields: [billId], references: [id], onDelete: Restrict)

  @@index([billId])
  @@index([invoiceNumber])
  @@index([customerId, noteDate])
  @@index([supplierId, noteDate])
  @@index([financialYear])
  @@index([status])
  @@index([documentType, status])
  @@map("invoice_notes")
}

model VoucherCounter {
  id            String @id @default(uuid())
  type          String
  financialYear String
  lastValue     Int    @default(0)

  @@unique([type, financialYear])
  @@map("voucher_counters")
}

enum LedgerAccountType {
  ACCOUNTS_RECEIVABLE
  BANK_CASH
  SALES
}

enum VoucherType {
  RECEIPT
  PAYMENT
  CONTRA
  JOURNAL
}

enum NoteType {
  DEBIT_NOTE
  CREDIT_NOTE
}

enum DocumentType {
  SALE
  PURCHASE
}

enum BalanceEffect {
  INCREASE
  DECREASE
}

enum NoteStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum PaymentMethod {
  NEFT_RTGS
  CHEQUE
  CASH
  UPI
}

enum EntryType {
  DEBIT
  CREDIT
}
